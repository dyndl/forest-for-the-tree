# ─── COPY THIS TO .env.local AND FILL IN ───────────────────────────────────
# Never commit .env.local to git

# NextAuth
NEXTAUTH_URL=https://YOUR_VERCEL_APP.vercel.app
NEXTAUTH_SECRET=run_this_in_terminal: openssl rand -base64 32

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (for Whisper audio transcription)
OPENAI_API_KEY=your_openai_api_key

# Supabase (from supabase.com project settings)
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cron secret (make up any random string)
CRON_SECRET=make_up_a_random_string_here
