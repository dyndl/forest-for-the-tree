# Local env files — never commit these
.env
.env.local
.env.*.local

# Dependencies
node_modules/

# Next.js build output
.next/
out/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Vercel
.vercel

